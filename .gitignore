# Heavy geodata is excluded from git by default.
# We can add selected H3 hex outputs later when needed.
data/*

# Small app runtime inputs that must be present on Streamlit Cloud.
!data/raw/
!data/raw/AreaDemand.xlsx
!data/processed/
!data/processed/speedlocal_times.duckdb

# R session artifacts
.Rhistory
.RData
.Rproj.user/

# Python artifacts
__pycache__/
*.pyc
.venv/

# VS Code local workspace artifacts
.vscode/*.log

# Office / local presentation artifacts
~$*.pptx
*_backup_before_codex.pptx

# Local temporary helper scripts
tmp_patch_*.R

# Local R plot scratch outputs
Rplot*.png
